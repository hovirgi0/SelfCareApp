<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appGradientBackground">

    <ImageView
            android:id="@+id/imgSettingsIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="40dp"
            android:contentDescription="Settings icon"
            android:onClick="onSettingsClicked"
            android:src="@drawable/settings_24px"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnBackground"/>

    <TextView
            android:id="@+id/tvSettingsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beállítások"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/imgSettingsIcon"
            app:layout_constraintStart_toStartOf="@id/imgSettingsIcon"
            app:layout_constraintEnd_toEndOf="@id/imgSettingsIcon"
            android:fontFamily="?attr/mainAppFontFamily"
            android:textColor="?attr/colorOnBackground"/>

    <ImageView
            android:id="@+id/SentimentIconSmall"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="15dp"
            android:contentDescription="Sentiment Indicator"
            android:src="@drawable/ic_heart"
            app:layout_constraintTop_toBottomOf="@id/imgSettingsIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvChatPromptSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miben lehetek ma melletted?"
            android:textSize="21sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/SentimentIconSmall"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/titleAppFontFamily"/>

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatHistory"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvChatPromptSmall"
            app:layout_constraintBottom_toTopOf="@id/cgChatSuggestions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_chat_bubble" />

    <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgChatSuggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvChatPromptSmall"
            app:layout_constraintBottom_toTopOf="@id/llInputBar"
            app:layout_constraintVertical_bias="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
                android:id="@+id/chipChat1"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stresszes vagyok"
                android:textSize="17sp"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <com.google.android.material.chip.Chip
                android:id="@+id/chipChat2"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jól érzem magam"
                android:textSize="17sp"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <com.google.android.material.chip.Chip
                android:id="@+id/chipChat3"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teendőim vannak"
                android:textSize="17sp"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <com.google.android.material.chip.Chip
                android:id="@+id/chipChat4"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Naplót írnék"
                android:textSize="17sp"
                android:visibility="gone"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <com.google.android.material.chip.Chip
                android:id="@+id/chipChat5"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Csak beszélgetnék"
                android:textSize="17sp"
                android:visibility="gone"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <com.google.android.material.chip.Chip
                android:id="@+id/chipChatMore"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textSize="17sp"
                android:fontFamily="?attr/mainAppFontFamily"/>
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
            android:id="@+id/llInputBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:layout_margin="16dp"
            android:background="?attr/cardDefaultBackground"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <EditText
                android:id="@+id/etChatMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Válaszolj..."
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:fontFamily="?attr/mainAppFontFamily"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant" />

        <ImageButton
                android:id="@+id/btnSendMessage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/send_24px"
                app:tint="?attr/colorPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:onClick="onSendMessageClicked" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>