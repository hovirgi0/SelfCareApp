<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.chat.ChatActivity"
        android:background="?attr/appSceneBackground">

    <ImageView
            android:id="@+id/imgSettingsIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Settings icon"
            android:src="@drawable/settings_icon_foreground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/tvSettingsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beállítások"
            android:textSize="10sp"
            android:onClick="onSettingsClicked"
            app:layout_constraintTop_toBottomOf="@id/imgSettingsIcon"
            app:layout_constraintEnd_toEndOf="@id/imgSettingsIcon"
            app:layout_constraintStart_toStartOf="@id/imgSettingsIcon"
            android:fontFamily="?attr/mainAppFontFamily"/>

    <ImageView
            android:id="@+id/imgChatIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="64dp"
            android:src="@drawable/ic_app_placeholder"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvChatPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miben tudok ma segíteni?"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgChatIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/titleAppFontFamily"
    />

    <Button
            android:id="@+id/btnStartChat"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="Kezdjük el"
            app:cornerRadius="0dp"
            android:layout_marginTop="120dp"
            android:onClick="onStartChatClicked"
            app:layout_constraintTop_toBottomOf="@id/tvChatPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"/>

</androidx.constraintlayout.widget.ConstraintLayout>