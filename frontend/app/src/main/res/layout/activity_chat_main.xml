<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.chat.ChatActivity"
        android:background="?attr/appGradientBackground">

    <ImageView
            android:id="@+id/imgSettingsIcon"
            android:layout_width="36dp"
            android:layout_height="65dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Settings icon"
            android:src="@drawable/settings_24px"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnBackground"/>

    <TextView
            android:id="@+id/tvSettingsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Beállítások"
            android:textSize="14sp"
            android:onClick="onSettingsClicked"
            app:layout_constraintTop_toBottomOf="@id/imgSettingsIcon"
            app:layout_constraintEnd_toEndOf="@id/imgSettingsIcon"
            app:layout_constraintStart_toStartOf="@id/imgSettingsIcon"
            android:fontFamily="?attr/mainAppFontFamily"
            android:textColor="?attr/colorOnBackground"/>

    <ImageView
            android:id="@+id/imgChatIcon"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="64dp"
            android:src="@drawable/ic_heart"
            app:layout_constraintTop_toBottomOf="@id/imgSettingsIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvChatPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miben lehetek ma melletted?"
            android:textSize="23sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgChatIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/titleAppFontFamily"/>

    <Button
            android:id="@+id/btnStartChat"
            android:layout_width="150dp"
            android:layout_height="65dp"
            android:textSize="20sp"
            android:text="Kezdjük el"
            android:layout_marginTop="120dp"
            android:onClick="onStartChatClicked"
            app:layout_constraintTop_toBottomOf="@id/tvChatPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"
            android:textColor="?attr/colorOnBackground"/>

</androidx.constraintlayout.widget.ConstraintLayout>