<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.MainMenuActivity"
        android:background="?attr/android:colorBackground">

    <!-- TODO: replace with user name from personalization -->
        <TextView
                android:id="@+id/tvMenuGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <ImageView
                android:id="@+id/imgSettingsIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="Settings icon"
                android:src="@drawable/settings_24px"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:tint="?attr/colorOnSurface"/>

        <TextView
                android:id="@+id/tvSettingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beállítások"
                android:textSize="10sp"
                app:layout_constraintTop_toBottomOf="@id/imgSettingsIcon"
                app:layout_constraintEnd_toEndOf="@id/imgSettingsIcon"
                app:layout_constraintStart_toStartOf="@id/imgSettingsIcon"
                android:fontFamily="?attr/mainAppFontFamily"/>

    <ImageView
            android:id="@+id/imgAppIcon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:contentDescription="App icon"
            android:src="@mipmap/ic_launcher"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Mire akarsz ma fókuszálni?" 
                android:textStyle="bold"
                android:textSize="15sp"
                app:layout_constraintTop_toBottomOf="@id/imgAppIcon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:fontFamily="?attr/titleAppFontFamily"/>

        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                app:columnCount="2"
                app:rowCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvQuestion"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

            <Button
                    android:id="@+id/btnTasks"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    app:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Teendő lista"
                    android:backgroundTint="?attr/colorPrimary"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <Button
                    android:id="@+id/btnJournal"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    app:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Napló"
                    android:backgroundTint="?attr/colorPrimary"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <Button
                    android:id="@+id/btnChat"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    app:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Chat"
                    android:backgroundTint="?attr/colorPrimary"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <Button
                    android:id="@+id/btnCustom"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    app:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:text="Button"
                    android:backgroundTint="?attr/colorPrimary"
                    android:fontFamily="?attr/mainAppFontFamily"/>
        </androidx.gridlayout.widget.GridLayout>

        <TextView
                android:id="@+id/tvFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Te döntöd el, mit jelent számodra a wellness."
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"/>

    </androidx.constraintlayout.widget.ConstraintLayout>