<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.personalization.NamePersonalizationActivity"
        android:background="?attr/appGradientBackground">

    <ImageView
            android:id="@+id/imgPersonalizationNameAppIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:contentDescription="App Icon"
            android:src="@drawable/heart_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvPersonalizationNameTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Üdv"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imgPersonalizationNameAppIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/titleAppFontFamily" />

    <View
            android:id="@+id/bgContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="30dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:layout_marginBottom="50dp"
            app:layout_constraintTop_toBottomOf="@id/tvPersonalizationNameTitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="?attr/colorSurfaceVariant"
            android:alpha="0.9"/>

    <TextView
            android:id="@+id/tvExplanation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ez a te személyre szabott tered."
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginStart="64dp"
            android:layout_marginEnd="64dp"
            app:layout_constraintTop_toTopOf="@id/bgContent"
            app:layout_constraintStart_toStartOf="@id/bgContent"
            app:layout_constraintEnd_toEndOf="@id/bgContent"
            android:fontFamily="?attr/mainAppFontFamily"/>

    <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hogyan szólítsunk?"
            android:textSize="15sp"
            android:layout_marginTop="64dp"
            app:layout_constraintTop_toBottomOf="@id/tvExplanation"
            app:layout_constraintStart_toStartOf="@id/tilName"
            android:fontFamily="?attr/mainAppFontFamily"
    />

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:hintEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvQuestion"
            app:layout_constraintStart_toStartOf="@id/bgContent"
            app:layout_constraintEnd_toEndOf="@id/bgContent"
            android:fontFamily="?attr/mainAppFontFamily">

        <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Írd be a neved"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="12dp"
                android:fontFamily="?attr/mainAppFontFamily"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
            android:id="@+id/btnContinue"
            android:layout_width="150dp"
            android:layout_height="65dp"
            android:text="Következő"
            android:textSize="18sp"
            app:cornerRadius="0dp"
            android:layout_marginTop="24dp"
            android:onClick="onNameContinueClicked"
            app:layout_constraintTop_toBottomOf="@id/tilName"
            app:layout_constraintStart_toStartOf="@id/bgContent"
            app:layout_constraintEnd_toEndOf="@id/bgContent"
            android:fontFamily="?attr/mainAppFontFamily"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary"/>

    <TextView
            android:id="@+id/tvtextLast"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Szeretném, ha az app valóban neked szólna."
            android:textSize="15dp"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintBottom_toBottomOf="@id/bgContent"
            app:layout_constraintStart_toStartOf="@id/bgContent"
            app:layout_constraintEnd_toEndOf="@id/bgContent"
            android:fontFamily="?attr/mainAppFontFamily"/>

</androidx.constraintlayout.widget.ConstraintLayout>