<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appGradientBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="15dp">

        <!-- Header -->
        <LinearLayout
                android:id="@+id/llHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:clipToOutline="true"
                android:padding="14dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

            <TextView
                    android:id="@+id/tvSettingsGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Állítsd be a chat társadat úgy, hogy a legjobban megfeleljen neked. Ezek a beállítások bármikor módosíthatók."
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="?attr/mainAppFontFamily"/>
        </LinearLayout>

        <!-- Preview Box -->
        <LinearLayout
                android:id="@+id/llPreviewBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="35dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:clipToOutline="true"
                android:padding="12dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/llHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Előnézet"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chat_bubble"
                    android:padding="10dp"
                    android:layout_gravity="center"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <View
                        android:layout_width="12dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="6dp"/>

                <TextView
                        android:id="@+id/tvPreviewText"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:text="Értem, amit mondasz. Ez valóban kihívást jelenthet. Szeretnél beszélni róla részletesebben?"
                        android:textSize="14sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Válassz különböző kombinációkat, hogy megtaláld, mi illik hozzád!"
                    android:textSize="13sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:fontFamily="?attr/mainAppFontFamily"/>
        </LinearLayout>

        <!-- Tone title -->
        <TextView
                android:id="@+id/tvToneTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat társ hangneme"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/llPreviewBox"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"
                android:textColor="?attr/colorOnSurface"/>

        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glTone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvToneTitle"
                android:layout_marginTop="6dp">

            <LinearLayout
                    android:id="@+id/cardToneNeutral"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semleges"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="12sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kiegyensúlyozott hang."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardToneFriendly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barátságos"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="12sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Meleg, kedves stílus."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardToneCalm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nyugodt"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lassú, békés tempó."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardToneEnergetic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Energikus"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lelkesítő és aktív."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

        </androidx.gridlayout.widget.GridLayout>

        <TextView
                android:id="@+id/tvStyleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Válasz stílusa"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/glTone"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvStyleTitle"
                android:layout_marginTop="6dp">

            <LinearLayout
                    android:id="@+id/cardStyleSupportive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Támogató"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Együttérző válaszok."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardStyleDirect"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Direkt"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lényegre törő."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

        </androidx.gridlayout.widget.GridLayout>

        <TextView
                android:id="@+id/tvThemeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alkalmazás témája"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/glStyle"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvThemeTitle"
                android:layout_marginTop="6dp">

            <LinearLayout
                    android:id="@+id/cardThemeDopamineBright"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dopamine Bright"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Világos és energikus téma."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardThemeDopamineDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dopamine Dark"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sötét és élénk megjelenés."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardThemeSoothingLight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soothing Light"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lágy és nyugodt világos téma."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardThemeSoothingDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soothing Dark"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nyugodt sötét megjelenés."
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:fontFamily="?attr/mainAppFontFamily"/>
            </LinearLayout>

        </androidx.gridlayout.widget.GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>