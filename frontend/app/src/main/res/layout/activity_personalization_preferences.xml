<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.personalization.PreferencesPersonalizationActivity"
        android:background="?attr/android:colorBackground">

        <ImageView
                android:id="@+id/imgAppIcon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:contentDescription="App icon"
                android:src="@mipmap/ic_launcher"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Mihez van szükséged támogatásra?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                app:layout_constraintTop_toBottomOf="@id/imgAppIcon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:fontFamily="?attr/titleAppFontFamily"/>

        <TextView
                android:id="@+id/tvExplanation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Válasz ki azt ami a legfontosabb számodra. Ez segít abban, hogy (personalize your experience)."
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                app:layout_constraintTop_toBottomOf="@id/tvQuestion"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <View
                android:id="@+id/bgOptionsContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#D9D9D9"
                android:layout_marginTop="24dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                app:layout_constraintTop_toBottomOf="@id/tvExplanation"
                app:layout_constraintBottom_toTopOf="@id/tvFooterNote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
                android:id="@+id/llOptions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                app:layout_constraintTop_toTopOf="@id/bgOptionsContainer"
                app:layout_constraintBottom_toBottomOf="@id/bgOptionsContainer"
                app:layout_constraintStart_toStartOf="@id/bgOptionsContainer"
                app:layout_constraintEnd_toEndOf="@id/bgOptionsContainer">

            <Button
                    android:id="@+id/btnOption1"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Option 1"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center_vertical|start"
                    android:paddingStart="16dp"
                    app:cornerRadius="0dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <Button
                    android:id="@+id/btnOption2"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Option 1"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center_vertical|start"
                    android:paddingStart="16dp"
                    app:cornerRadius="0dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="?attr/mainAppFontFamily"/>

            <Button
                    android:id="@+id/btnOption3"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Option 3"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:backgroundTint="#FFFFFF"
                    android:gravity="center_vertical|start"
                    android:paddingStart="16dp"
                    app:cornerRadius="0dp"
                    android:fontFamily="?attr/mainAppFontFamily"/>
        </LinearLayout>

     <TextView
            android:id="@+id/tvFooterNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nincs helyes vagy helytelen használat"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="50dp"
            app:layout_constraintTop_toBottomOf="@id/bgOptionsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"/>

        <Button
                android:id="@+id/btnContinue"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="Következő"
                android:backgroundTint="#000000"
                android:textColor="#FFFFFF"
                app:cornerRadius="0dp"
                android:layout_marginBottom="48dp"
                android:onClick="onPreferencesContinueClicked"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:fontFamily="?attr/mainAppFontFamily"/>

    </androidx.constraintlayout.widget.ConstraintLayout>