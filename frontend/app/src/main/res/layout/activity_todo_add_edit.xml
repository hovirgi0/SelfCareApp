<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.todo.ToDoAddEditActivity"
        android:background="?attr/appGradientBackground">

    <ImageView
            android:id="@+id/imgAppIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:src="@mipmap/ic_launcher"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Új teendő létrehozása"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/imgAppIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"/>

    <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNewTask"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="8dp"
            app:hintEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSaveTask"
            android:fontFamily="?attr/mainAppFontFamily">

        <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTaskName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#D9D9D9"
                android:hint="Új teendő"
                android:inputType="textCapSentences"
                android:padding="12dp"
                android:fontFamily="?attr/mainAppFontFamily"/>
    </com.google.android.material.textfield.TextInputLayout>

    <ImageButton
            android:id="@+id/btnSaveTask"
            android:onClick="onSaveTaskClicked"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp"
            android:src="@drawable/add_box_24px"

            app:tint="#000000"
            app:fabSize="normal"
            app:layout_constraintTop_toTopOf="@id/tilNewTask"
            app:layout_constraintBottom_toBottomOf="@id/tilNewTask"
            app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgSuggestions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintTop_toBottomOf="@id/tilNewTask"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggestion1"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tanulás"
                android:fontFamily="?attr/mainAppFontFamily"/>

        <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggestion2"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Takarítás"
                android:fontFamily="?attr/mainAppFontFamily" />

        <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggestion3"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bevásárlás"
                android:fontFamily="?attr/mainAppFontFamily" />

        <!-- Suggestions hidden by default -->
        <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggestion4"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edzés"
                android:visibility="gone"
                android:fontFamily="?attr/mainAppFontFamily" />

        <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggestion5"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:visibility="gone"
                android:fontFamily="?attr/mainAppFontFamily" />

        <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggestion6"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vacsora főzés"
                android:visibility="gone"
                android:fontFamily="?attr/mainAppFontFamily" />

        <com.google.android.material.chip.Chip
                android:id="@+id/chipMore"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/more_horiz_24px"
                android:fontFamily="?attr/mainAppFontFamily" />
    </com.google.android.material.chip.ChipGroup>

    <Button
            android:id="@+id/btnCancel"
            android:onClick="onCancelClicked"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mégse"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#000000"
            android:layout_marginBottom="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily" />

</androidx.constraintlayout.widget.ConstraintLayout>