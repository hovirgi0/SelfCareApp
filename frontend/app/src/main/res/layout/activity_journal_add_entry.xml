<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.journal.JournalAddEntryActivity"
        android:background="?attr/appGradientBackground">

    <ImageView
            android:id="@+id/imgJournalAppIcon"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:contentDescription="Journal Icon"
            android:src="@drawable/heart_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Napló"
            android:textStyle="bold"
            android:textSize="22sp"
            app:layout_constraintTop_toBottomOf="@id/imgJournalAppIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/titleAppFontFamily"/>

    <TextView
            android:id="@+id/tvMoodPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hogy érzed ma magad?"
            android:textSize="19sp"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"/>

    <LinearLayout
            android:id="@+id/llMoodSelector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvMoodPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <ImageView
                android:id="@+id/moodSad"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/sentiment_sad_24px"
                android:onClick="onMoodEntrySelected"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground"/>

        <ImageView
                android:id="@+id/moodNeutral"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/sentiment_neutral_24px"
                android:onClick="onMoodEntrySelected"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground"/>

        <ImageView
                android:id="@+id/moodHappy"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/sentiment_satisfied_24px"
                android:onClick="onMoodEntrySelected"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground"/>

        <ImageView
                android:id="@+id/moodGreat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/sentiment_very_satisfied_24px"
                android:onClick="onMoodEntrySelected"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground"/>

    </LinearLayout>

    <TextView
            android:id="@+id/tvReflectPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesélj a napodról:"
            android:textSize="19sp"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/llMoodSelector"
            app:layout_constraintStart_toStartOf="@id/etJournalEntry"
            android:fontFamily="?attr/mainAppFontFamily"/>

    <EditText
            android:id="@+id/etJournalEntry"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="8dp"
            android:gravity="top"
            android:padding="12dp"
            android:hint="Írj ide..."
            android:inputType="textMultiLine"
            app:layout_constraintTop_toBottomOf="@id/tvReflectPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"
            android:background="?attr/cardDefaultBackground"/>

    <Button
            android:id="@+id/btnSaveEntry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bejegyzés mentése"
            android:textSize="18sp"
            android:layout_marginTop="22dp"
            android:onClick="onSaveEntryClicked"
            app:layout_constraintTop_toBottomOf="@id/etJournalEntry"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"
            android:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary"/>

    <TextView
            android:id="@+id/tvJournalTips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:textSize="14sp"
            android:text="Tippek a naplózáshoz:\nÍrj úgy, ahogy jól esik, nincs jó vagy rossz módja.\nA naplód csak a tiéd, ezért légy őszinte magaddal."
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnSaveEntry"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"/>

</androidx.constraintlayout.widget.ConstraintLayout>