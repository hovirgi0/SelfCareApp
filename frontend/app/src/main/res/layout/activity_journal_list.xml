<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.journal.JournalActivity"
        android:background="?attr/appGradientBackground">

    <ImageView
            android:id="@+id/imgJournalAppIcon"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="12dp"
            android:contentDescription="App Icon"
            android:src="@drawable/heart_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvJournalTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Napló"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imgJournalAppIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/titleAppFontFamily" />

    <TextView
            android:id="@+id/tvPreviousEntries"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Korábbi bejegyzéseid:"
            android:textSize="19sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvJournalTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily"/>

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvJournalEntries"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvPreviousEntries"
            app:layout_constraintBottom_toTopOf="@id/fabAddEntry"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_journal_entry"/>

    <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Még nincsenek bejegyzéseid."
            android:textSize="17sp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/rvJournalEntries"
            app:layout_constraintBottom_toBottomOf="@id/rvJournalEntries"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fontFamily="?attr/mainAppFontFamily" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddEntry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:contentDescription="Bejegyzés hozzáadása"
            android:src="@android:drawable/ic_input_add"
            app:fabSize="normal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:textColor="?attr/colorOnBackground"/>

</androidx.constraintlayout.widget.ConstraintLayout>