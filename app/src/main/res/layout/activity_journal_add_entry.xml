<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.journal.JournalAddEntryActivity">

    <ImageView
            android:id="@+id/imgJournalIconSmall"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:src="@mipmap/ic_launcher"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Napló"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/imgJournalIconSmall"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvMoodPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hogy érzed ma magad?"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
            android:id="@+id/llMoodSelector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvMoodPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <TextView
                android:id="@+id/moodSad"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="😢"
                android:textSize="24sp"
                android:gravity="center"
                android:onClick="onMoodSelected"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
                android:id="@+id/moodNeutral"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="😐"
                android:textSize="24sp"
                android:gravity="center"
                android:onClick="onMoodSelected"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
                android:id="@+id/moodHappy"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="😊"
                android:textSize="24sp"
                android:gravity="center"
                android:onClick="onMoodSelected"
                android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
                android:id="@+id/moodGreat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="😃"
                android:textSize="24sp"
                android:gravity="center"
                android:onClick="onMoodSelected"
                android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <TextView
            android:id="@+id/tvReflectPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mesélj a napodról:"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/llMoodSelector"
            app:layout_constraintStart_toStartOf="@id/etJournalEntry" />

    <EditText
            android:id="@+id/etJournalEntry"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="8dp"
            android:background="#D9D9D9"
            android:gravity="top"
            android:padding="12dp"
            android:hint="Írj ide..."
            android:inputType="textMultiLine"
            app:layout_constraintTop_toBottomOf="@id/tvReflectPrompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <Button
            android:id="@+id/btnSaveEntry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bejegyzés mentése"
            android:backgroundTint="#000000"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"
            android:onClick="onSaveEntryClicked"
            app:layout_constraintTop_toBottomOf="@id/etJournalEntry"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <TextView
            android:id="@+id/tvJournalTips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            android:textSize="10sp"
            android:text="Tippek a naplózáshoz:\n• Nincs helyes vagy helytelen módja - írj úgy, ahogy neked jó\n• Nem kell minden nap írni, csak akkor, ha szeretnél\n• A naplód csak a tiéd - senki más nem látja\n• Próbálj őszinte lenni magaddal - ez a te biztonságos tered"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>