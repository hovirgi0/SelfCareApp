<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

        <!-- Header -->
        <LinearLayout
                android:id="@+id/llHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:orientation="vertical"
                android:background="#EFEFEF"
                android:padding="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

            <TextView
                    android:id="@+id/tvSettingsGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Állítsd be a chat társadat úgy, hogy a legjobban megfeleljen neked. Ezek a beállítások bármikor módosíthatók."
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Preview Box -->
        <LinearLayout
                android:id="@+id/llPreviewBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="35dp"
                android:orientation="vertical"
                android:background="#9E9E9E"
                android:padding="8dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/llHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Előnézet"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp"/>

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/white"
                    android:padding="8dp"
                    android:layout_gravity="center"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <View
                        android:layout_width="12dp"
                        android:layout_height="18dp"
                        android:background="#D9D9D9"
                        android:layout_marginEnd="6dp" />

                <TextView
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:textColor="#000000"
                        android:text="Értem, amit mondasz. Ez valóban kihívást jelenthet. Szeretnél beszélni róla részletesebben?"
                        android:textSize="10sp"/>
            </LinearLayout>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Válassz különböző kombinációkat, hogy megtaláld, mi illik hozzád!"
                    android:textSize="9sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:textColor="#424242"/>
        </LinearLayout>

        <!-- Tone title -->
        <TextView
                android:id="@+id/tvToneTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat társ hangneme"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@id/llPreviewBox"
                app:layout_constraintStart_toStartOf="parent"/>

        <!-- Tone grid -->
        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glTone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvToneTitle"
                android:layout_marginTop="6dp">

            <LinearLayout
                    android:id="@+id/cardToneNeutral"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Semleges" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kiegyensúlyozott hang." android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardToneFriendly"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Barátságos" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Meleg, kedves stílus." android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardToneCalm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nyugodt" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lassú, békés tempó." android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardToneEnergetic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Energikus" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lelkesítő és aktív." android:textSize="9sp"/>
            </LinearLayout>
        </androidx.gridlayout.widget.GridLayout>

        <!-- Style title -->
        <TextView
                android:id="@+id/tvStyleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Válasz stílusa"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/glTone"
                app:layout_constraintStart_toStartOf="parent"/>

        <!-- Style grid -->
        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvStyleTitle"
                android:layout_marginTop="6dp">

            <LinearLayout
                    android:id="@+id/cardStyleSupportive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Támogató" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Együttérző válaszok." android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardStyleDirect"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Direkt" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lényegre törő." android:textSize="9sp"/>
            </LinearLayout>
        </androidx.gridlayout.widget.GridLayout>

        <!-- Theme title -->
        <TextView
                android:id="@+id/tvThemeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alkalmazás témája"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/glStyle"
                app:layout_constraintStart_toStartOf="parent"/>

        <!-- Theme grid -->
        <androidx.gridlayout.widget.GridLayout
                android:id="@+id/glTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:layout_constraintTop_toBottomOf="@id/tvThemeTitle"
                android:layout_marginTop="6dp">

            <LinearLayout
                    android:id="@+id/cardThemeLight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Világos" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Letisztult fehér." android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardThemeDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#000000"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sötét" android:textStyle="bold" android:textColor="#FFFFFF" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kíméli a szemet." android:textSize="9sp" android:textColor="#FFFFFF"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardThemeNatural"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Természetes" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Föld színek és nyugalom." android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardThemeMinimal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:padding="10dp"
                    android:background="#F2F2F2"
                    android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Minimál" android:textStyle="bold" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Csak a legszükségesebbek." android:textSize="9sp"/>
            </LinearLayout>

        </androidx.gridlayout.widget.GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>