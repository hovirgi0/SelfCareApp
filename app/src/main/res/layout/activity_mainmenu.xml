<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.MainMenuActivity">

    <!-- Greeting -->
    <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Szia, Név!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- Settings icon -->
    <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="@id/tvGreeting"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="16dp"
            android:onClick="onSettingsClicked" />

    <!-- Profile / Mood placeholder -->
    <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="24dp"
            android:contentDescription="Profile placeholder"
            app:layout_constraintTop_toBottomOf="@id/tvGreeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- Focus question -->
    <TextView
            android:id="@+id/tvFocusQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mire akarsz ma fókuszálni?"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/imgProfile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- Feature buttons grid -->

    <Button
            android:id="@+id/btnTodo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Teendő lista"
            android:layout_marginTop="24dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="16dp"
            android:onClick="onTodoClicked"
            app:layout_constraintTop_toBottomOf="@id/tvFocusQuestion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnJournal" />

    <Button
            android:id="@+id/btnJournal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Napló"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="32dp"
            android:onClick="onJournalClicked"
            app:layout_constraintTop_toBottomOf="@id/tvFocusQuestion"
            app:layout_constraintStart_toEndOf="@id/btnTodo"
            app:layout_constraintEnd_toEndOf="parent" />

    <Button
            android:id="@+id/btnChat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Chat"
            android:layout_marginTop="16dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="16dp"
            android:onClick="onChatClicked"
            app:layout_constraintTop_toBottomOf="@id/btnTodo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnExtra" />

    <Button
            android:id="@+id/btnExtra"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Egyéb"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintTop_toBottomOf="@id/btnJournal"
            app:layout_constraintStart_toEndOf="@id/btnChat"
            app:layout_constraintEnd_toEndOf="parent" />

    <!-- Footer philosophy -->
    <TextView
            android:id="@+id/tvFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Te döntöd el, mit jelent számodra a wellness."
            android:textSize="12sp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>