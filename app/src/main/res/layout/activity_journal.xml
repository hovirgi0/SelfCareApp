<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

    <!-- Napló cím -->
    <TextView
            android:id="@+id/journal_root"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/journal"
            android:textSize="20sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

    <!-- Napló beviteli mező -->
    <EditText
            android:id="@+id/etJournalEntry"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:hint="@string/write_your_thoughts_here"
            android:inputType="text"
            android:gravity="top"
            android:background="@android:drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/journal_root"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

    <!-- Mentés gomb -->
    <Button
            android:id="@+id/btnSaveEntry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/save_entry"
            app:layout_constraintTop_toBottomOf="@id/etJournalEntry"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>