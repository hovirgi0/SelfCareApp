<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#D9D9D9"
        android:padding="16dp">

    <View
            android:id="@+id/viewMoodColor"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="#A6A6A6"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/tvEntryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textSize="12sp"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/viewMoodColor"
            app:layout_constraintTop_toTopOf="@id/viewMoodColor"
            app:layout_constraintBottom_toBottomOf="@id/viewMoodColor" />

    <View
            android:id="@+id/viewTextPlaceholder"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="#A6A6A6"
            app:layout_constraintTop_toBottomOf="@id/viewMoodColor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>